  "events": [
    {
      "id": "action_network:0974e9ff-5c0c-4294-8fa2-492b2a2f4710",
      "name": "HealthCare WG Labor subcommittee meeting",
      "date": "2026-07-19T12:30:00Z",
      "date_formatted": "12:30 PM, Sunday July 19, 2026",
      "month_year": "2026-07",
      "month_label": "July 2026",
      "status": "confirmed",
      "description": "<p>Join us to discuss mapping our organizations, NYHA education, union outreach/ strategy session, and ways to support healthcare organizing campaigns throughout the city. In person participation is encouraged, but a zoom link will be shared before the meeting.</p>",
      "browser_url": "https://actionnetwork.org/events/healthcare-wg-labor-subcommittee-meeting",
      "signup_url": "https://actionnetwork.org/events/healthcare-wg-labor-subcommittee-meeting",
      "location": "14 Jefferson St.",
      "borough": "New York"
    },
    {
      "id": "action_network:fcccc6f3-924e-48fe-ad88-06779bb9d915",
      "name": "Dive-In to Fight for Healthcare",
      "date": "2026-07-25T14:00:00Z",
      "date_formatted": "2:00 PM, Saturday July 25, 2026",
      "month_year": "2026-07",
      "month_label": "July 2026",
      "status": "confirmed",
      "description": "<p>Meeting to hear pros and cons on our resolution to focus Healthcare working group energies on passing NYHA and applying and winning priority status in the chapter. You should receive a copy of this very brief resolution by email to review and comment or submit amendment ahead of the meeting. We will vote online, in the days following the meeting. We will also breakout by geographic branch to discuss strategies to engage in our branches. There will be time for updates and announcements and after we invite all to jump in the pool with us! Everybody In Nobody Out! LOL.</p>",
      "browser_url": "https://actionnetwork.org/events/dive-in-to-fight-for-healthcare",
      "signup_url": "https://actionnetwork.org/events/dive-in-to-fight-for-healthcare",
      "location": "Shore Blvd, Astoria",
      "borough": "Queens"
    },
    {
      "id": "action_network:5d28fa00-2935-461d-93d6-a359f1b2b1f4",
      "name": "New York Health Act 101",
      "date": "2026-08-07T18:30:00Z",
      "date_formatted": "6:30 PM, Friday August 7, 2026",
      "month_year": "2026-08",
      "month_label": "August 2026",
      "status": "confirmed",
      "description": "<p>Come learn about the New York Health Act, a bill to de-privatize healthcare and send the extortionist insurance companies packing. No more premiums, deductibles, and co pays! No denials of care or medication and no restricted networks! There will be time Q&A and discussion.</p>",
      "browser_url": "https://actionnetwork.org/events/back-groundintro-to-new-york-health-act",
      "signup_url": "https://actionnetwork.org/events/back-groundintro-to-new-york-health-act",
      "location": "14 Jefferson St.",
      "borough": "New York"
    },
